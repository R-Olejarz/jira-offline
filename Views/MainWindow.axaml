<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:JiraOffline.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="500"
        x:Class="JiraOffline.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/AppIcon.ico"
        xmlns:views="using:JiraOffline.Views"
        Title="Jira Offline"
        Width="550"
        Height="600"
        MinWidth="400"
        MinHeight="400"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource AppBackgroundBrush}">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Grid RowDefinitions="*,Auto">

        <ListBox
            x:Name="TaskList"
            Grid.Row="0"
            Margin="5,10"
            ItemsSource="{Binding Items}"
            SelectedItem="{Binding SelectedItem}"
            Background="Transparent"
            BorderThickness="0">
            
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <views:TodoItemView />
                </DataTemplate>
            </ListBox.ItemTemplate>

        </ListBox>

        <Border
            Grid.Row="1"
            Margin="8"
            Padding="12"
            Background="{DynamicResource TaskCardBackgroundBrush}"
            BorderBrush="{DynamicResource TaskCardBorderBrush}"
            BorderThickness="1"
            CornerRadius="10">

            <Grid
                ColumnDefinitions="*,Auto"
                ColumnSpacing="12">

                <Grid
                    Grid.Column="0"
                    ColumnDefinitions="*,110"
                    ColumnSpacing="10">

                    <TextBox
                        Grid.Column="0"
                        Height="46"
                        VerticalContentAlignment="Center"
                        Text="{Binding NewItemTitle}"
                        PlaceholderText="Type new task">
                        <TextBox.KeyBindings>
                            <KeyBinding
                                Gesture="Enter"
                                Command="{Binding AddItemCommand}" />
                        </TextBox.KeyBindings>
                    </TextBox>
                    
                    <ComboBox
                        Grid.Column="1"
                        Height="46"
                        Width="100"
                        Classes="priority-select"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Center"
                        ItemsSource="{Binding Priorities}"
                        SelectedItem="{Binding NewItemPriority}" />
                </Grid>

                <Button
                    Grid.Column="1"
                    Height="46"
                    Classes="primary"
                    HorizontalAlignment="Center"
                    VerticalContentAlignment="Center"
                    Content="Create"
                    Padding="20,5"
                    Command="{Binding AddItemCommand}" />

            </Grid>
        </Border>

    </Grid>

</Window>